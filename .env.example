# Server
INTERNAL_SERVICE_TOKEN=change-this-token
RUST_LOG=info

# Rate limiting
REDIS_URL=redis://127.0.0.1/
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_S=60

# OAuth2 / OIDC
OAUTH2_STRATEGY=jwks              # jwks | introspect | discovery
OIDC_ISSUER=https://idp.example.com/realms/myrealm
OIDC_AUDIENCE=my-api
OIDC_CLIENT_ID=my-api
OIDC_REDIRECT_URI=https://api.example.com/callback
OIDC_REQUIRED_SCOPES=api:read    # comma-separated, all must be present
JWKS_REFRESH_SECS=3600
OAUTH2_CLOCK_SKEW_SECS=60

# Only needed for introspection strategy
INTROSPECT_CLIENT_ID=
INTROSPECT_CLIENT_SECRET=
